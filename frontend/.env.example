# Файл .env кладите в папку frontend/ (рядом с package.json).
# Скопируйте: copy .env.example .env  (из каталога frontend)
# Значения — из Supabase: Project Settings → API
# В Vite переменные для браузера должны начинаться с VITE_

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Telegram Integration (for Supabase Edge Function) ---
# Set these via `supabase secrets set ...` in Supabase CLI or locally in .env for functions.
# TELEGRAM_BOT_TOKEN=your-bot-token
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Только npm run dev: пропустить экран входа (реальный email/пароль тестового пользователя) ---
# В Supabase: Authentication → Providers → Email → выключить «Confirm email».
# Пароль в .env не коммитьте (файл .env в .gitignore).
# VITE_DEV_AUTO_LOGIN=true
# VITE_DEV_AUTO_LOGIN_EMAIL=dev@example.com
# VITE_DEV_AUTO_LOGIN_PASSWORD=your-dev-password
